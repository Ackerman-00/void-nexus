# Template file for 'hyprland'
pkgname=hyprland
version=0.54.2
revision=1
build_style=cmake
configure_args+=" --no-warn-unused-cli"
configure_args+=" -DCMAKE_BUILD_TYPE:STRING=Release"
configure_args+=" -DCMAKE_INSTALL_PREFIX:PATH=/usr"
configure_args+=" -DNO_SYSTEMD:BOOL=true"
othermakedepends="
  cmake
  cpio
  gcc
  glslang
  hyprwayland-scanner
  jq
  make
  meson
  ninja
  pkgconf
  wayland-devel
"
hostmakedepends=$othermakedepends
makedepends="
  aquamarine
  cairo-devel
  glaze
  hwids
  hyprcursor
  hyprgraphics
  hyprlang
  hyprutils
  hyprwire
  libdisplay-info-devel
  libdrm-devel
  libgbm-devel
  libglvnd-devel
  libinput-devel
  libliftoff-devel
  libseat-devel
  libxcb-devel
  libXcursor-devel
  libxkbcommon-devel
  muparser-devel
  pango-devel
  re2-devel
  tomlplusplus
  wayland-devel
  wayland-protocols
  xcb-util-errors-devel
  xcb-util-renderutil-devel
  xcb-util-wm-devel
  xorg-server-xwayland
"
short_desc="Dynamic tiling Wayland compositor that doesn't sacrifice on its looks"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="BSD-3-Clause"
homepage="https://hyprland.org/"
changelog="https://github.com/hyprwm/Hyprland/releases"
distfiles="https://github.com/hyprwm/Hyprland/releases/download/v${version}/source-v${version}.tar.gz"
checksum=723d9cf86ad09b2f01d2cc403ac5799f9d6ad69a438b43a8f7b7589122eafd1b
if [ "$XBPS_TARGET_LIBC" = "musl" ]; then
  configure_args+=" -DCMAKE_CXX_FLAGS=\"-lexecinfo\""
  makedepends+=" libexecinfo-devel"
  depends+=" libexecinfo"
fi
pre_configure() {
  # Run all GCC 14 / C++23 compatibility fixes via Python
  python3 << 'PYEOF'
import os, re

fixes = 0

def fix_file(path):
    global fixes
    try:
        content = open(path).read()
        orig = content

        # 1. Replace #embed (C23, GCC 15+) with byte array
        if '#embed' in content and 'defaultConfig.hpp' in path:
            conf = open('example/hyprland.conf', 'rb').read()
            arr = ', '.join(str(b) for b in conf)
            content = content.replace('#embed "../../example/hyprland.conf"', arr)

        # 2. Replace append_range (C++23 ranges, GCC 15+)
        def fix_append_range(m):
            vec = m.group(1)
            rng = m.group(2).strip()
            return f'{{ auto _r = {rng}; {vec}.insert({vec}.end(), _r.begin(), _r.end()); }}'
        content = re.sub(
            r'([\w.->]+)\.append_range\(([^;]+)\);',
            fix_append_range, content)

        # 3. Replace insert_range (C++23 ranges, GCC 15+)
        def fix_insert_range(m):
            vec = m.group(1)
            it  = m.group(2).strip()
            rng = m.group(3).strip()
            return f'{{ auto _r = {rng}; {vec}.insert({it}, _r.begin(), _r.end()); }}'
        content = re.sub(
            r'([\w.->]+)\.insert_range\(([^,]+),\s*([^;]+)\);',
            fix_insert_range, content)

        # 4. Fix CXCBConnection ternary vs nullptr_t (C++26 type deduction)
        content = content.replace(
            'return m_connection ? *m_connection : nullptr;',
            'return m_connection ? *m_connection : (xcb_connection_t*)nullptr;')

        # 5. Fix string + string_view (C++26 operator+)
        content = re.sub(
            r'\+ "/" \+ (instanceSignature) \+ "/" \+ (filename)',
            lambda m: f'+ "/" + std::string({m.group(1)}) + "/" + std::string({m.group(2)})',
            content)

        if content != orig:
            open(path, 'w').write(content)
            fixes += 1
            print(f'Fixed: {path}')
    except Exception as e:
        pass

for root, dirs, files in os.walk('.'):
    # skip build dir
    dirs[:] = [d for d in dirs if d != 'build']
    for f in files:
        if f.endswith(('.cpp', '.hpp', '.h', '.hxx')):
            fix_file(os.path.join(root, f))

print(f'Total files patched: {fixes}')
PYEOF

  # Downgrade C++ standard from 26 to 23 — GCC 14 libstdc++ incompatibility
  find ${wrksrc} -name "CMakeLists.txt" -exec sed -i \
    -e 's/CMAKE_CXX_STANDARD 26/CMAKE_CXX_STANDARD 23/g' \
    -e 's/-std=gnu++26/-std=gnu++23/g' \
    -e 's/-std=c++26/-std=c++23/g' {} +
}
post_install() {
  vlicense LICENSE
  vmkdir usr/include/hyprland
  vmkdir usr/include/hyprland/protocols
  vmkdir usr/share/pkgconfig
  cmake --build ./build --config Release --target generate-protocol-headers
  find src -type f \( -name '*.hpp' -o -name '*.h' -o -name '*.inc' \) -print0 | cpio --quiet -0dump ${DESTDIR}/usr/include/hyprland
  install -Dm0644 protocols/*.h* ${DESTDIR}/usr/include/hyprland/protocols
  vinstall build/hyprland.pc 644 usr/share/pkgconfig
}
hyprland-devel_package() {
  depends="${sourcepkg}>=${version}_${revision} ${othermakedepends} ${makedepends}"
  short_desc="Dynamic tiling Wayland compositor - development files"
  pkg_install() {
    vmove usr/include
    vmove usr/share/pkgconfig
  }
}
