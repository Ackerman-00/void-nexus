# Template file for 'zed'
pkgname=zed
version=0.230.0
revision=1
archs="x86_64* aarch64*"
build_style=cargo

# Override the cargo command to unset the hardcoded LIBGIT2_NO_VENDOR
make_cmd="env -u LIBGIT2_NO_VENDOR cargo"

make_install_args="--path crates/zed"
make_check_args="-- --test-threads 1"

hostmakedepends="
  clang18
  cmake
  gettext
  mold
  pkg-config
  protobuf
"
makedepends="
  alsa-lib-devel
  fontconfig-devel
  glib-devel
  libX11-devel
  libxcb-devel
  libxkbcommon-devel
  libzstd-devel
  openssl-devel
  sqlite-devel
  vulkan-loader
  wayland-devel
"
depends="git"
checkdepends="noto-fonts-ttf"
short_desc="High-performance, multiplayer code editor from the creators of Atom"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="GPL-3.0-or-later, Apache-2.0, AGPL-3.0-or-later"
homepage="https://zed.dev"
changelog="https://github.com/zed-industries/zed/releases"
distfiles="https://github.com/zed-industries/zed/archive/refs/tags/v${version}.tar.gz"
checksum=69390981c840c909319614800fafca761d81807391659a28762a27ccecd19396

post_install() {
	vlicense ${wrksrc}/LICENSE-AGPL
	APP_NAME="Zed" DO_STARTUP_NOTIFY="true" APP_ICON="zed" APP_CLI="zed" \
		envsubst < ${wrksrc}/crates/zed/resources/zed.desktop.in \
		> ${wrksrc}/crates/zed/resources/dev.zed.Zed.desktop
	vinstall ${wrksrc}/crates/zed/resources/dev.zed.Zed.desktop \
		644 usr/share/applications/
	vinstall ${wrksrc}/crates/zed/resources/app-icon.png \
		644 usr/share/icons/hicolor/512x512/apps/zed.png
}
