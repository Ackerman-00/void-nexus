# Template file for 'dsearch'
pkgname=dsearch
version=0.2.1
revision=2
build_style=go
wrksrc="danksearch-${version}"
go_import_path=github.com/AvengeMedia/danksearch
go_package="${go_import_path}/cmd/dsearch"
short_desc="Fast configurable filesystem search service"
maintainer="Tony King <tonyking94@proton.me>"
license="MIT"
homepage="https://danklinux.com/docs/danksearch"
changelog="https://github.com/AvengeMedia/danksearch/releases"
distfiles="https://github.com/AvengeMedia/danksearch/archive/refs/tags/v${version}.tar.gz"
checksum="e2c263a233e45661e55bd841ee1395b9241132091f1b1e3d98caebb26d455727"

system_accounts="dsearch"
make_dirs="
 /var/lib/dsearch 0755 dsearch dsearch
 /var/log/dsearch 0755 dsearch dsearch
 /etc/dsearch 0755 root root
"

conf_files="/etc/dsearch/config.toml"

do_install() {
	vbin ${GOPATH}/bin/dsearch
}

post_install() {
	if [ -f LICENSE ]; then
		vlicense LICENSE
	fi

	if [ -f config.example.toml ]; then
		vinstall config.example.toml 0644 etc/dsearch config.toml
	fi

	vsv dsearch
}
