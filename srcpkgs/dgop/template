# Template file for 'dgop'
pkgname=dgop
version=0.2.3
revision=1
build_style=go
go_import_path="github.com/AvengeMedia/dgop"
go_package="${go_import_path}/cmd/dgop"
short_desc="Stateless, cursor-based system and process monitoring tool"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="MIT"
homepage="https://github.com/AvengeMedia/dgop"

distfiles="https://github.com/AvengeMedia/dgop/archive/refs/tags/v${version}.tar.gz"
checksum="afd2f9542ce25c739b13d6213fdfbc5493bce537d5afec309b4df945e318ff1a"

post_install() {
    if [ -f "config.sample.toml" ]; then
        vmkdir etc/dgop
        vinstall config.sample.toml 0644 etc/dgop config.toml
    fi

    if [ -f "LICENSE" ]; then
        vlicense LICENSE
    fi
}
