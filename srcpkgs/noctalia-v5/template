# Template file for 'noctalia-v5'
pkgname=noctalia-v5
_basever=5.0.0
_commit=b6fd0df7a4d992a19acb7261be8b5b260f03e5d4
_shortcommit=b6fd0df
_gitdate=20260706041000
version="${_basever}+git${_gitdate}.${_shortcommit}"
revision=1

_gitbranch="main"
wrksrc="noctalia-${_commit}"

build_style=meson
buildtype=release
configure_args="-Db_ndebug=true -Dtests=disabled"
short_desc="Lightweight Wayland shell built directly on Wayland and OpenGL ES"
