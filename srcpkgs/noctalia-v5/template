# Template file for 'noctalia-v5'
pkgname=noctalia-v5
_basever=5.0.0
_commit=5c7e2fba2338125339c6556b5cfb0ca5864ea448
_shortcommit=5c7e2fb
_gitdate=20260711013944
version="${_basever}+git${_gitdate}.${_shortcommit}"
revision=1

_gitbranch="main"
wrksrc="noctalia-${_commit}"

build_style=meson
buildtype=release
configure_args="-Db_ndebug=true -Dtests=disabled"
short_desc="Lightweight Wayland shell built directly on Wayland and OpenGL ES"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="MIT"
