# Template file for 'heroic-games-launcher'
pkgname=heroic-games-launcher
version=2.22.0
revision=2
archs="x86_64"
short_desc="Open source launcher for GOG, Epic, and Amazon Games"
maintainer="Quietcraft <ackerman-00@users.noreply.github.com>"
license="GPL-3.0-or-later"
homepage="https://heroicgameslauncher.com"

distfiles="https://github.com/Heroic-Games-Launcher/HeroicGamesLauncher/releases/download/v${version}/Heroic-${version}-linux-x64.tar.xz"
checksum="5aa127f204ca793181ec33d15b5f556c2f27b5734698ab0436a6590a73974571"

depends="desktop-file-utils hicolor-icon-theme nss atk alsa-lib libcups libdrm libgbm \
 libXcomposite libXdamage libXrandr libXScrnSaver gtk+3 libxcb"

nostrip=yes

do_install() {
	vmkdir opt/heroic
	vcopy "*" opt/heroic

	vmkdir usr/bin
	ln -sf /opt/heroic/heroic ${DESTDIR}/usr/bin/heroic

	vmkdir usr/share/applications
	cat > ${DESTDIR}/usr/share/applications/heroic.desktop <<-DESKTOP
	[Desktop Entry]
	Type=Application
	Name=Heroic Games Launcher
	Comment=Open source launcher for GOG, Epic, and Amazon Games
	Icon=heroic
	Exec=heroic %u
	Terminal=false
	Categories=Game;
	MimeType=x-scheme-handler/heroic;
	StartupWMClass=heroic
	DESKTOP

	vmkdir usr/share/icons/hicolor/512x512/apps
	vinstall resources/app.asar.unpacked/build/icon.png 644 \
		usr/share/icons/hicolor/512x512/apps heroic.png

	chmod 755 ${DESTDIR}/opt/heroic/heroic
	if [ -f ${DESTDIR}/opt/heroic/chrome-sandbox ]; then
		chmod 4755 ${DESTDIR}/opt/heroic/chrome-sandbox
	fi
}
