# Template file for 'heroic-games-launcher'
pkgname=heroic-games-launcher
version=2.20.1
revision=2
archs="x86_64"
build_style=fetch
short_desc="Open source launcher for GOG, Epic, and Amazon Games"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="GPL-3.0-or-later"
homepage="https://heroicgameslauncher.com"

distfiles="https://github.com/Heroic-Games-Launcher/HeroicGamesLauncher/releases/download/v${version}/Heroic-${version}-linux-amd64.deb"
checksum=4e9957436bc270318b00a1107910a3c7d30ad72da530af4dee5c2860866a6272

# Dependencies
depends="desktop-file-utils hicolor-icon-theme nss atk alsa-lib libcups libdrm libgbm 
 libXcomposite libXdamage libXrandr libXScrnSaver gtk+3 libxcb"

# bsdtar is mandatory for clean .deb handling
hostmakedepends="bsdtar"

# These internal binaries must NOT be stripped or they will break
_helper_path="opt/Heroic/resources/app.asar.unpacked/build/bin/x64/linux"
nopie_files="
 /opt/Heroic/heroic
 /opt/Heroic/chrome-sandbox
 /${_helper_path}/gogdl
 /${_helper_path}/legendary
 /${_helper_path}/nile
 /${_helper_path}/comet
 /${_helper_path}/vulkan-helper"

nostrip_files="${nopie_files}"

do_extract() {
    # CRITICAL: Using wildcard (*) to support both .xz and .zst compression
    bsdtar xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/Heroic-${version}-linux-amd64.deb data.tar.*
    bsdtar xf data.tar.* -C .
}

do_install() {
    # 1. Install the main application folder
    vmkdir opt
    cp -a opt/Heroic ${DESTDIR}/opt/

    # 2. Install desktop entries and icons
    vmkdir usr/share
    cp -a usr/share/applications ${DESTDIR}/usr/share/
    cp -a usr/share/icons ${DESTDIR}/usr/share/

    # 3. Create the executable symlink
    vmkdir usr/bin
    ln -sf /opt/Heroic/heroic ${DESTDIR}/usr/bin/heroic

    # 4. Set correct permissions for the binary and SUID sandbox
    chmod 755 ${DESTDIR}/opt/Heroic/heroic
    if [ -f ${DESTDIR}/opt/Heroic/chrome-sandbox ]; then
        chmod 4755 ${DESTDIR}/opt/Heroic/chrome-sandbox
    fi
}
