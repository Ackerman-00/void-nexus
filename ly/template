# Template file for 'ly'
pkgname=ly
version=1.3.2
revision=6

# Host dependencies (tools needed to compile)
hostmakedepends="pkg-config zig git"

# Target dependencies
makedepends="pam-devel libxcb-devel"

# Runtime dependencies
depends="xorg-server-xwayland xauth dbus"

short_desc="TUI display manager with support for X11 and Wayland"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="WTFPL"
homepage="https://codeberg.org/fairyglade/ly"

distfiles="https://github.com/fairyglade/ly/archive/refs/tags/v${version}.tar.gz"
checksum=73254acc3c8974a24dbf308e77b096ad6fa2c8818da4d5b865173225602e87d1

post_patch() {
    # Fix: Zig 0.13+ syntax change - .name must be a string literal
    sed -i 's/\.name = \.ly,/.name = "ly",/g' build.zig.zon
}

# Manually commanding the Zig compiler
do_build() {
    zig build -Doptimize=ReleaseSafe -Dinit_system=runit -Dpam=true -Dxcb=true
}

# Manually placing all compiled files where Void expects them
do_install() {
    # 1. Install the main executable
    vbin zig-out/bin/ly
    
    # 2. Install the PAM configuration (CRITICAL for successful logins)
    vinstall res/pam.d/ly 0644 etc/pam.d ly
    
    # 3. Install the default config file
    vmkdir etc/ly
    vinstall res/config.ini 0644 etc/ly config.ini
    
    # 4. Copy language localization files if they exist
    if [ -d res/lang ]; then
        cp -a res/lang ${DESTDIR}/etc/ly/
    fi
    
    # 5. Create the Void Linux runit service natively
    vmkdir etc/sv/ly
    cat <<EOF > ${DESTDIR}/etc/sv/ly/run
#!/bin/sh
exec 2>&1
# Ensure Ly runs on tty2 by default
exec /usr/bin/ly
EOF
    chmod 755 ${DESTDIR}/etc/sv/ly/run
}
