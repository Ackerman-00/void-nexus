# Template file for 'tomlplusplus'
pkgname=tomlplusplus
version=3.4.0
revision=2
build_style=meson
hostmakedepends="cmake pkgconf"
short_desc="Header-only TOML config file parser and serializer for C++17"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="MIT"
homepage="https://marzer.github.io/tomlplusplus/"
distfiles="https://github.com/marzer/${pkgname}/archive/refs/tags/v${version}.tar.gz"
checksum=8517f65938a4faae9ccf8ebb36631a38c1cadfb5efa85d9a72e15b9e97d25155
post_install() {
	vlicense LICENSE
	vmkdir usr/lib/pkgconfig
	cat > "${DESTDIR}/usr/lib/pkgconfig/tomlplusplus.pc" <<-EOF
	prefix=/usr
	includedir=\${prefix}/include

	Name: tomlplusplus
	Description: Header-only TOML config file parser and serializer for C++17
	Version: ${version}
	Cflags: -I\${includedir}
	EOF
}
