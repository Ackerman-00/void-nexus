# Template file for 'dankmaterialshell'
pkgname=dankmaterialshell
version=1.4.4
revision=1
build_style=fetch
depends="quickshell-git qt6-declarative qt6-wayland pam"
short_desc="A Material You inspired shell for Wayland"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="GPL-3.0-or-later"
homepage="https://github.com/AvengeMedia/DankMaterialShell"

distfiles="https://github.com/AvengeMedia/DankMaterialShell/archive/refs/tags/v${version}.tar.gz"
checksum=9a23a717eef088da3d25b355d4f13feff7499bbafe5e93c9fa379ee15e962709

do_install() {
    # Quickshell configs usually live in XDG paths.
    vmkdir etc/xdg/quickshell/DankMaterialShell
    cp -a ${wrksrc}/* ${DESTDIR}/etc/xdg/quickshell/DankMaterialShell/
}
