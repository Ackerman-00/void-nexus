# Template file for 'rootapp'
pkgname=rootapp
version=0.9.108
revision=1
archs="x86_64* aarch64*"
depends="gtk+3 nss libnotify alsa-lib xdg-utils at-spi2-core"
short_desc="Discord alternative for gaming communities and large online groups"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="custom"
homepage="https://www.rootapp.com"

case "$XBPS_TARGET_MACHINE" in
	x86_64*)
		distfiles="https://installer.rootapp.com/installer/Linux/X64/Root.AppImage>Root-${version}-x86_64.AppImage"
		checksum=ed2cdd497f32b62e39810fc92ada9acd8c1471f6d2935ccc88774a758fd45519
		;;
	aarch64*)
		distfiles="https://installer.rootapp.com/installer/Linux/Arm64/Root.AppImage>Root-${version}-aarch64.AppImage"
		checksum=7eb2e7e60671e14db57e56d099754ea0a64437607ff11168d88e1751ff2d873f
		;;
esac

nostrip=yes

do_extract() {
	local _appimage="${XBPS_SRCDISTDIR}/${pkgname}-${version}/Root-${version}-*.AppImage"
	chmod +x ${_appimage}
	${_appimage} --appimage-extract
}

do_install() {
	vmkdir opt/rootapp
	cp -a squashfs-root/* "${DESTDIR}/opt/rootapp/"
	chmod 755 "${DESTDIR}/opt/rootapp/AppRun"

	vmkdir usr/bin
	ln -sf /opt/rootapp/AppRun "${DESTDIR}/usr/bin/rootapp"

	vinstall squashfs-root/Root.png 0644 usr/share/pixmaps rootapp.png

	vmkdir usr/share/icons/hicolor/256x256/apps
	cp squashfs-root/Root.png "${DESTDIR}/usr/share/icons/hicolor/256x256/apps/rootapp.png"

	vmkdir usr/share/applications
	cat > "${DESTDIR}/usr/share/applications/rootapp.desktop" <<-EOF
[Desktop Entry]
Type=Application
Name=Root
Comment=Root App is a new Discord alternative, designed for gaming communities and large online groups
Exec=env AVALONIA_PLATFORM=wayland rootapp %U
Icon=rootapp
Terminal=false
StartupWMClass=Root
Categories=Network;InstantMessaging;
EOF
}
