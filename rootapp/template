# Template file for 'rootapp'
pkgname=rootapp
version=20260321
revision=2
# Restricted to x86_64 to avoid checksum zero-failures
archs="x86_64"
build_style=fetch
depends="gtk+3 nss libnotify alsa-lib xdg-utils at-spi2-core icu fontconfig freetype"
short_desc="Discord alternative for gaming communities"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="custom"
homepage="https://www.rootapp.com"

distfiles="https://installer.rootapp.com/installer/Linux/X64/Root.AppImage>Root-${version}.AppImage"
checksum=b81d23935e1db25e5dc5f857944fe71e072e3895db1c0c8195bd178374737206
nostrip_files="/opt/rootapp/*"

do_extract() {
    local _appimage="${XBPS_SRCDISTDIR}/${pkgname}-${version}/Root-${version}.AppImage"
    chmod +x "${_appimage}"
    "${_appimage}" --appimage-extract
}

do_install() {
    vmkdir opt/rootapp
    cp -a squashfs-root/* ${DESTDIR}/opt/rootapp/
    vmkdir usr/bin
    ln -sf /opt/rootapp/AppRun ${DESTDIR}/usr/bin/rootapp
    vinstall squashfs-root/Root.png 0644 usr/share/pixmaps rootapp.png
}
