# Template file for 'noctalia-v5'
pkgname=noctalia-v5
_basever=5.0.0
_commit=108e8a55d6e59643138837abb8ef7bfb51cfb34e
_shortcommit=108e8a5
_gitdate=20260620083546
version="${_basever}+git${_gitdate}.${_shortcommit}"
revision=1

_gitbranch="main"
wrksrc="noctalia-${_commit}"

build_style=meson
buildtype=release
configure_args="-Db_ndebug=true"
short_desc="Lightweight Wayland shell built directly on Wayland and OpenGL ES"
maintainer="Noctalia <team@noctalia.dev>"
license="MIT"
homepage="https://github.com/noctalia-dev/noctalia"

distfiles="https://github.com/noctalia-dev/noctalia/archive/${_commit}.tar.gz"
checksum="743a60b61566fec07e06db71095cd034842c19faedf8917dc933158d64966f28"

conflicts="noctalia>=0"
provides="noctalia-${version}_${revision}"

CXXFLAGS="-std=c++23 -Wno-unused-result"

hostmakedepends="meson ninja pkg-config git curl"

makedepends="
 wayland-devel wayland-protocols libglvnd-devel libepoxy-devel cairo-devel
 pango-devel fontconfig-devel freetype-devel harfbuzz-devel libxkbcommon-devel
 pipewire-devel libcurl-devel pam-devel libwebp-devel basu-devel sdbus-c++-devel
 polkit-devel librsvg-devel jemalloc-devel glib-devel libqalculate-devel libxml2-devel
"

post_install() {
    vlicense LICENSE
    vdoc README.md

    if [ ! -x "${DESTDIR}/usr/bin/noctalia" ]; then
        msg_error "Expected binary /usr/bin/noctalia not found.\n"
    fi
}
