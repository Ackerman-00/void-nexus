# Template file for 'noctalia-v5'
pkgname=noctalia-v5
_basever=5.0.0
_commit=72b216ce2416e0904616286078b3f5be037d9f77
_shortcommit=72b216c
_gitdate=20260610043910
version="${_basever}+git${_gitdate}.${_shortcommit}"
revision=1

_gitbranch="main"
wrksrc="noctalia-${_commit}"

build_style=meson
