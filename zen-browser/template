# Template file for 'zen-browser'
pkgname=zen-browser
version=1.19.3b
revision=1
archs="x86_64 aarch64"
build_style=fetch
hostmakedepends="xz"
depends="desktop-file-utils hicolor-icon-theme libnotify libavcodec xdg-utils"
short_desc="Welcome to a calmer internet"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="MPL-2.0"
homepage="https://www.zen-browser.app/"

case "${XBPS_TARGET_MACHINE}" in
x86_64*)
    _upstream_arch=x86_64
    _checksum=3b03eaeecfb222ecd62d37b9d6d409d704ce2437ff8286626e17b0289eb60c91
    ;;
aarch64*)
    _upstream_arch=aarch64
    _checksum=78d45f75527146b59f49e806d220b7872091443965b727132703edd110661988
    ;;
*) broken="No distfiles available for this target" ;;
esac

distfiles="https://github.com/zen-browser/desktop/releases/download/${version}/zen.linux-${_upstream_arch}.tar.xz
 https://raw.githubusercontent.com/zen-browser/desktop/refs/heads/dev/LICENSE>LICENSE"
checksum="${_checksum}
c76f740d1521b9bed9ca7a04ad526c310493c62621b1341d623b431736533b30"

do_install() {
    vmkdir opt/zen-browser
    
    # 1. locate and install the application files
    if [ -f "zen" ] || [ -f "zen-bin" ]; then
        # Files were dumped directly into the root of wrksrc
        for f in *; do
            if [ "$f" != "LICENSE" ]; then
                cp -a "$f" ${DESTDIR}/opt/zen-browser/
            fi
        done
    elif [ -d "zen" ]; then
        # Extracted to 'zen' directory
        cp -a zen/* ${DESTDIR}/opt/zen-browser/
    elif [ -d "zen-browser" ]; then
        # Extracted to 'zen-browser' directory
        cp -a zen-browser/* ${DESTDIR}/opt/zen-browser/
    else
        # Find where the core 'browser' directory is hiding
        local _zdir=$(find . -maxdepth 2 -name "browser" -type d | head -n 1)
        if [ -n "$_zdir" ]; then
            cp -a $(dirname "$_zdir")/* ${DESTDIR}/opt/zen-browser/
        fi
    fi

    # 2. Symlink the executable to the user's PATH dynamically
    vmkdir usr/bin
    if [ -f "${DESTDIR}/opt/zen-browser/zen" ]; then
        ln -sf /opt/zen-browser/zen ${DESTDIR}/usr/bin/zen
    elif [ -f "${DESTDIR}/opt/zen-browser/zen-bin" ]; then
        ln -sf /opt/zen-browser/zen-bin ${DESTDIR}/usr/bin/zen
    fi

    # 3. Install desktop entries and policies
    vinstall ${FILESDIR}/zen.desktop 0644 usr/share/applications/
    
    vmkdir opt/zen-browser/distribution
    vinstall ${FILESDIR}/policies.json 644 opt/zen-browser/distribution/

    # 4. Install icons directly from newly copied directory
    vinstall ${DESTDIR}/opt/zen-browser/browser/chrome/icons/default/default48.png 0644 usr/share/pixmaps zen.png
    for size in 16 32 48 64 128; do
        vmkdir usr/share/icons/hicolor/${size}x${size}/apps
        vinstall ${DESTDIR}/opt/zen-browser/browser/chrome/icons/default/default${size}.png 0644 usr/share/icons/hicolor/${size}x${size}/apps zen.png
    done

    # 5. Link system dictionaries
    ln -sf /usr/share/hunspell ${DESTDIR}/opt/zen-browser/dictionaries
    ln -sf /usr/share/hyphen ${DESTDIR}/opt/zen-browser/hyphenation
    
    # 6. Install License
    if [ -f "LICENSE" ]; then
        vlicense LICENSE
    fi
}
